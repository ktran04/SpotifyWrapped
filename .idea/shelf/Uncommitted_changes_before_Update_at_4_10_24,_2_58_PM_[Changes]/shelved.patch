\"\n        android:layout_height=\"wrap_content\"\n        android:layout_below=\"@+id/buttonDeleteAccount\"\n        android:layout_marginTop=\"16dp\"\n        android:backgroundTint=\"#1DB954\"\n        android:text=\"Sign Out\" />\n\n    <Button\n        android:id=\"@+id/genWrappedActivity\"\n        android:layout_width=\"348dp\"\n        android:layout_height=\"wrap_content\"\n        android:layout_below=\"@+id/buttonSignOut\"\n        android:layout_marginStart=\"87dp\"\n        android:layout_marginTop=\"51dp\"\n        android:layout_marginEnd=\"87dp\"\n        android:background=\"#D1768F\"\n        android:backgroundTint=\"#1DB954\"\n        android:text=\"Make New Wrapped\" />\n\n    <Button\n        android:id=\"@+id/buttonPastSpotifyWrapped\"\n        android:layout_width=\"338dp\"\n        android:layout_height=\"wrap_content\"\n        android:layout_below=\"@+id/genWrappedActivity\"\n        android:layout_marginStart=\"93dp\"\n        android:layout_marginTop=\"50dp\"\n        android:layout_marginEnd=\"92dp\"\n        android:background=\"#D1768F\"\n        android:backgroundTint=\"#1DB954\"\n        android:text=\"Get Past Wrappeds\" />\n\n    <Button\n        android:id=\"@+id/quizButton\"\n        android:layout_width=\"219dp\"\n        android:layout_height=\"wrap_content\"\n        android:layout_below=\"@+id/buttonPastSpotifyWrapped\"\n        android:layout_alignParentStart=\"true\"\n        android:layout_alignParentEnd=\"true\"\n        android:layout_marginStart=\"84dp\"\n        android:layout_marginTop=\"61dp\"\n        android:layout_marginEnd=\"92dp\"\n        android:text=\"What's My Taste?\" />\n\n</RelativeLayout>\n
