<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:gravity="center">

    <!-- Header for Delete Account -->
    <TextView
        android:id="@+id/textViewDeleteAccountHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delete Account"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="36dp" />

    <!-- Text box for entering email -->
    <EditText
        android:id="@+id/editTextEmailToDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/textViewDeleteAccountHeader"
        android:layout_marginBottom="16dp"
        android:hint="Enter Email" />

    <!-- Button to delete account -->
    <Button
        android:id="@+id/deleteButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/editTextEmailToDelete"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:text="Delete" />

</RelativeLayout>
